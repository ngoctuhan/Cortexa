# ── Required ──────────────────────────────────────────────────────────────────
# For local dev with docker-compose, use sslmode=disable (postgres runs locally).
# For production (RDS, Cloud SQL, etc.), use sslmode=require.
DATABASE_URL=postgres://user:password@localhost:5432/cortexa?sslmode=disable
MASTER_KEY=                          # openssl rand -hex 32

# ── LLM provider (set one) ────────────────────────────────────────────────────
# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-01

# OpenAI
# OPENAI_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# REDIS_ADDR=localhost:6379
# REDIS_POOL_SIZE=100
# PORT=8080
# DB_MAX_CONNS=100
COGNITIVE_BATCH_SIZE=10      # default; set to 1 only for local testing
# COGNITIVE_PROMPT_PATH=prompts/cognitive.j2
